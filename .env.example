# Base URL of the API server (no trailing slash).
# Local development:
VITE_API_URL=http://localhost:4000

# Production (set this in the Vercel project's Environment Variables, NOT here):
#   VITE_API_URL=https://collaborative-idea-board-api-production.up.railway.app
#
# NOTE: VITE_* vars are inlined at BUILD time, so you must set this in Vercel
# and trigger a redeploy for changes to take effect.
